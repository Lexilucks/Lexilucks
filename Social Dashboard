<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ── Constants ──────────────────────────────────────────────────────────────────
const PINFO = {
  twitter:   { icon:'𝕏',  label:'Twitter/X',  color:'#1da1f2' },
  tiktok:    { icon:'♪',  label:'TikTok',     color:'#fe2c55' },
  discord:   { icon:'💬', label:'Discord',    color:'#7289da' },
  instagram: { icon:'📸', label:'Instagram',  color:'#e1306c' },
  onlyfans:  { icon:'🔞', label:'OnlyFans',   color:'#00aff0' },
};

// ── State ──────────────────────────────────────────────────────────────────────
let platformStatus = {};
let selectedPlatforms = new Set();
let mediaFile = null;
let postType = 'feed';
let queueFilter = null;
let calDate = new Date();

// ── Init ───────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', async () => {
  await refreshStatus();
  setupDrop();
  setupCharCount();
  const d = new Date(Date.now()+3600000);
  document.getElementById('sched-dt').value = d.toISOString().slice(0,16);
  loadComposeWidgets();
});

// ── Navigation ─────────────────────────────────────────────────────────────────
const PAGE_LOADERS = {
  queue:       loadQueue,
  calendar:    renderCalendar,
  history:     loadHistory,
  analytics:   loadAnalytics,
  'best-times':loadBestTimes,
  hashtags:    loadHashtagSets,
  templates:   loadTemplates,
  voice:       loadVoiceProfile,
  media:       loadMediaLibrary,
  drafts:      loadDrafts,
};

function nav(page) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+page)?.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(b=>b.classList.toggle('active', b.getAttribute('onclick')===`nav('${page}')`));
  if (PAGE_LOADERS[page]) PAGE_LOADERS[page]();
  document.getElementById('mobile-nav')?.classList.remove('open');
}

function toggleMobileNav() {
  const mn = document.getElementById('mobile-nav');
  mn.classList.toggle('open');
  // Populate mobile nav
  document.getElementById('mobile-nav-items').innerHTML = document.querySelector('.sidenav').innerHTML;
}

// ── Compose tabs ──────────────────────────────────────────────────────────────
function cTab(t, btn) {
  ['write','ai','results'].forEach(x=>{
    document.getElementById('ct-'+x).classList.toggle('active', x===t);
  });
  btn.closest('.itabs').querySelectorAll('.itab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function setType(t, btn) {
  postType = t;
  document.querySelectorAll('.type-pill').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

// ── Platform status ────────────────────────────────────────────────────────────
async function refreshStatus() {
  try {
    const res = await fetch('/api/status');
    platformStatus = await res.json();
    renderPlatformUI();
    loadComposeWidgets();
  } catch { toast('Server not reachable','error'); }
}

function renderPlatformUI() {
  // Main platform grid
  const pg = document.getElementById('plt-grid');
  if (pg) pg.innerHTML = Object.entries(PINFO).map(([p,info])=>{
    const on=platformStatus[p], sel=selectedPlatforms.has(p);
    return `<div class="plt-card ${on?'live':''} ${sel?'sel':''} ${!on?'dead':''}" onclick="togglePlt('${p}',${!!on})">
      <div class="plt-icon">${info.icon}</div>
      <div class="plt-name">${info.label}</div>
      <div class="plt-indicator"></div>
    </div>`;
  }).join('');

  // Sidebar compose status
  const cs = document.getElementById('compose-status');
  if (cs) cs.innerHTML = Object.entries(PINFO).map(([p,info])=>`
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:12px">
      <span>${info.icon}</span>
      <span style="flex:1;color:var(--sub)">${info.label}</span>
      <span style="font-size:10px;font-weight:600;color:${platformStatus[p]?'var(--green)':'var(--dim)'}">${platformStatus[p]?'✅':'⏳'}</span>
    </div>`).join('');

  // Sidebar nav status
  const ns = document.getElementById('nav-platform-status');
  if (ns) ns.innerHTML = Object.entries(PINFO).map(([p,info])=>`
    <div class="ps-item"><div class="ps-dot ${platformStatus[p]?'on':''}"></div>${info.label}</div>`).join('');

  // Setup banner
  const anyInactive = Object.values(platformStatus).some(v=>!v);
  const banner = document.getElementById('setup-banner');
  if (banner) banner.classList.toggle('show', anyInactive);
}

function togglePlt(p, on) {
  if (!on) { toast(`${PINFO[p]?.label} needs API tokens first`,'error'); return; }
  selectedPlatforms.has(p) ? selectedPlatforms.delete(p) : selectedPlatforms.add(p);
  renderPlatformUI();
}

// ── Load compose sidebar widgets ───────────────────────────────────────────────
async function loadComposeWidgets() {
  // Queue stats mini
  try {
    const res = await fetch('/api/queue');
    const data = await res.json();
    const s = data.stats;
    const cq = document.getElementById('compose-queue');
    if (cq) cq.innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        ${[['Scheduled',s.scheduled,'var(--violet)'],['Published',s.published,'var(--green)']].map(([l,v,c])=>`
          <div style="background:var(--s3);border-radius:7px;padding:10px;text-align:center">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:${c}">${v}</div>
            <div style="font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:.06em">${l}</div>
          </div>`).join('')}
      </div>`;
  } catch {}

  // Hashtag sets quick insert
  try {
    const sets = await fetch('/api/hashtags').then(r=>r.json());
    const ch = document.getElementById('compose-hashtags');
    if (ch) {
      if (!sets.length) { ch.innerHTML = '<div style="color:var(--dim);font-size:12px">No hashtag sets — <a onclick="nav(\'hashtags\')" style="color:var(--violet);cursor:pointer">create one</a></div>'; return; }
      ch.innerHTML = sets.map(s=>`<div class="tag-set" style="cursor:pointer" onclick="insertHashtags('${esc(s.tags)}')">
        <div style="font-size:11px;font-weight:600;margin-bottom:4px">${esc(s.name)} <span style="font-size:9px;color:var(--dim);font-weight:400">— click to insert</span></div>
        <div class="tag-chips">${s.tags.split(/[\s,]+/).filter(Boolean).slice(0,6).map(t=>`<span class="tag-chip">${esc(t)}</span>`).join('')}</div>
      </div>`).join('');
    }
  } catch {}
}

function insertHashtags(tags) {
  const ta = document.getElementById('caption');
  ta.value = (ta.value.trim() + '\n\n' + tags).trim();
  toast('Hashtags added ✓','success');
}

// ── Char count ─────────────────────────────────────────────────────────────────
function setupCharCount() {
  const ta = document.getElementById('caption');
  const cc = document.getElementById('char-count');
  if (!ta||!cc) return;
  ta.addEventListener('input',()=>{
    const l=ta.value.length;
    cc.textContent=`${l} / 280`;
    cc.className='char-count'+(l>280?' over':l>240?' warn':'');
  });
}

// ── Media drop ─────────────────────────────────────────────────────────────────
function setupDrop() {
  const zone = document.getElementById('mz');
  if (!zone) return;
  zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('over');});
  zone.addEventListener('dragleave',()=>zone.classList.remove('over'));
  zone.addEventListener('drop',e=>{e.preventDefault();zone.classList.remove('over');if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);});
  document.getElementById('file-in').addEventListener('change',e=>{if(e.target.files[0])handleFile(e.target.files[0]);});
}

function handleFile(f) {
  mediaFile=f;
  document.getElementById('mz').classList.add('loaded');
  document.getElementById('mz-def').style.display='none';
  const p=document.getElementById('mz-prev'); p.classList.add('show');
  document.getElementById('mz-name').textContent=`${f.name} (${(f.size/1024/1024).toFixed(1)}MB)`;
