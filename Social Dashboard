// ── Calendar ───────────────────────────────────────────────────────────────────
async function renderCalendar() {
  const qres=await fetch('/api/queue');
  const {queue}=await qres.json();
  const year=calDate.getFullYear(), month=calDate.getMonth();
  document.getElementById('cal-month-label').textContent=calDate.toLocaleString('en-US',{month:'long',year:'numeric'});
  const firstDay=new Date(year,month,1).getDay();
  const daysInMonth=new Date(year,month+1,0).getDate();
  const today=new Date();
  const grid=document.getElementById('cal-grid');
  const dows=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  let html=dows.map(d=>`<div class="cal-dow">${d}</div>`).join('');
  for(let i=0;i<firstDay;i++) html+=`<div class="cal-day other-month"></div>`;
  for(let d=1;d<=daysInMonth;d++){
    const isToday=today.getDate()===d&&today.getMonth()===month&&today.getFullYear()===year;
    const dayPosts=queue.filter(e=>{const ed=new Date(e.scheduleTime);return ed.getDate()===d&&ed.getMonth()===month&&ed.getFullYear()===year;});
    html+=`<div class="cal-day${isToday?' today':''}">
      <div class="cal-day-num">${d}</div>
      ${dayPosts.slice(0,3).map(e=>`<div class="cal-post-dot ${e.status}" title="${esc(e.caption?.slice(0,40)||'')}">${e.platforms?.[0]||'•'}</div>`).join('')}
      ${dayPosts.length>3?`<div style="font-size:9px;color:var(--dim)">+${dayPosts.length-3} more</div>`:''}
    </div>`;
  }
  grid.innerHTML=html;
}

